# ════════════════════════════════════════════════════════════════
#  OFFICE 2020 — шаблон окружения. Скопируйте в .env и впишите значения.
#  Реальный .env НЕ коммитится (в .gitignore).
# ════════════════════════════════════════════════════════════════

# ───────── PostgreSQL (контейнер db + приложение) ─────────
# Нужна поддержка расширения btree_gist (анти-овербукинг, ТЗ §4.6) —
# есть в стандартном образе postgres:16.
POSTGRES_USER=office2020
POSTGRES_PASSWORD=CHANGE_ME_strong_password   # openssl rand -hex 24
POSTGRES_DB=office2020

# Подключение приложения к БД:
#   • Docker (контейнер app строит URL из POSTGRES_* автоматически, host=db)
#   • с ХОСТА / своего сервера — укажите свой хост (host=127.0.0.1 для проброшенного порта)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/office2020?sslmode=disable"

# ───────── Auth.js — секрет подписи сессий ─────────
AUTH_SECRET="CHANGE_ME"   # openssl rand -base64 32

# ───────── Первый администратор (bootstrap при старте) ─────────
# Создаётся автоматически и идемпотентно при старте контейнера (scripts/ensure-admin.ts).
# Пароль применяется ТОЛЬКО при создании — дальше меняется через «Сброс пароля» в UI.
# Дальше этот админ заводит остальных сотрудников в разделе «Сотрудники».
# Если оставить пустыми — bootstrap пропускается (тогда пользователи приходят из db:seed).
ADMIN_PHONE="+77010000001"
ADMIN_PASSWORD="CHANGE_ME"          # надёжный пароль входа администратора
ADMIN_NAME="Администратор"          # опционально, по умолчанию «Администратор»

# ───────── Таймзона заведения ─────────
TZ="Asia/Almaty"
