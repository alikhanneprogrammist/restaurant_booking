// OFFICE 2020 — модель данных (см. ТЗ §5).
// Все временные поля — timestamptz (хранение UTC, отображение Asia/Almaty).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── Перечисления (§5.7) ─────────────────────────

enum Role {
  ADMIN
  MANAGER
}

enum ResourceKind {
  COMPLEX
  KARAOKE
}

enum Tariff {
  HOURLY
  HALF_DAY
  FULL_DAY
  WEEKEND
  CUSTOM
}

enum BookingStatus {
  NEW // Предварительная бронь
  CONFIRMED // Бронь / без предоплаты
  PREPAID // Бронь / предоплата
  ARRIVED // Пришли
  COMPLETED // Успешно реализовано
  CANCELLED // Не пришли / отмена (освобождает время)
  NO_SHOW // Не пришли / перенос (время остаётся занятым)
}

enum BookingSource {
  ADMIN
  PHONE
  WHATSAPP
  INSTAGRAM
  WIDGET
  TWO_GIS
  GOOGLE_SITE
  REGULAR // Постоянный гость
  RETURNING // Был ранее
  REFERRAL // По рекомендации
  AGENT // От агента
  OUTDOOR_AD // Наружная реклама
  BLOGGERS // Блогеры / UGC
  B2B
  BI_KMG_QAZGAZ
}

enum PaymentMethod {
  KASPI // Каспи
  CASH // Наличные
  BANK // Банк (перевод/счёт)
  CASH_KASPI // Нал/Каспи (смешанная оплата)
}

enum AddonUnit {
  PER_EVENT
  PER_ITEM
}

enum BookingAuditAction {
  CREATE
  UPDATE
  CANCEL
}

enum DiscountType {
  NONE
  PERCENT
  AMOUNT
}

// ───────────────────────── User — сотрудник (§5.1) ─────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  email        String?
  passwordHash String
  role         Role     @default(MANAGER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  bookings Booking[] @relation("BookingCreatedBy")
  bookingAudits BookingAudit[] @relation("BookingAuditUser")
}

// ───────────────────────── Resource — объект (§5.2) ────────────────────

model Resource {
  id        String       @id @default(cuid())
  kind      ResourceKind
  nameRu    String
  nameKk    String
  capacity  Int
  color     String       @default("#6366f1")
  photos    String[]     @default([])
  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)
  floor     Int          @default(1) // этаж ресторана (группировка столов в календаре)

  // Состав объекта
  floors          Json? // список этажей с описанием
  hasKaraoke      Boolean @default(false)
  hasFinnishSauna Boolean @default(false)
  hasHammam       Boolean @default(false)
  hasPool         Boolean @default(false)
  hasBanquet      Boolean @default(false)
  restRooms       Int     @default(0)
  hasKitchen      Boolean @default(false)
  extraInfo       String?

  // Тарифы (§4.9)
  hourlyPrice       Decimal  @db.Decimal(12, 2)
  minHours          Int      @default(3)
  halfDayPrice      Decimal? @db.Decimal(12, 2)
  fullDayPrice      Decimal? @db.Decimal(12, 2)
  weekendPrice      Decimal? @db.Decimal(12, 2)
  weekdayMinDeposit Decimal? @db.Decimal(12, 2)
  priceNote         String?

  bookings Booking[]
}

// ───────────────────────── ServiceAddon — доп.услуга (§5.3) ────────────

model ServiceAddon {
  id        String    @id @default(cuid())
  nameRu    String
  nameKk    String
  price     Decimal   @db.Decimal(12, 2)
  unit      AddonUnit @default(PER_ITEM)
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)

  bookingAddons BookingAddon[]
}

// ───────────────────────── Client — клиент (§5.4) ──────────────────────

model Client {
  id          String    @id @default(cuid())
  name        String
  phone       String    @unique
  note        String?
  tags        String[]  @default([])
  dateOfBirth DateTime? @db.Date // день рождения (только дата, без времени)
  createdAt   DateTime  @default(now())

  bookings Booking[]
}

// ───────────────────────── Booking — бронь (§5.5) ──────────────────────
// Exclusion constraint booking_no_overlap создаётся отдельной raw-SQL
// миграцией (см. ТЗ §4.6) — Prisma его не выражает декларативно.

model Booking {
  id         String   @id @default(cuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])

  startAt DateTime @db.Timestamptz(6)
  endAt   DateTime @db.Timestamptz(6)

  status BookingStatus @default(NEW)
  source BookingSource @default(ADMIN)
  tariff Tariff        @default(HOURLY)
  guests Int           @default(1)

  total         Decimal        @default(0) @db.Decimal(12, 2)
  deposit       Decimal        @default(0) @db.Decimal(12, 2)
  prepayment    Decimal        @default(0) @db.Decimal(12, 2)
  // Когда предоплата реально получена (для бухгалтерии: предзаказ сегодня — бронь в будущем).
  prepaidAt     DateTime?      @db.Timestamptz(6)
  paymentMethod PaymentMethod? // Каспи/Нал/Банк; null — не задано

  // Скидка по брони (§4.9): тип + значение (% или сумма ₸). Пишется в историю клиента.
  discountType  DiscountType @default(NONE)
  discountValue Decimal      @default(0) @db.Decimal(12, 2)

  comment     String?
  createdById String
  createdBy   User    @relation("BookingCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addons BookingAddon[]
  audits BookingAudit[]

  @@index([resourceId, startAt, endAt])
  @@index([clientId])
  @@index([createdById])
  @@index([prepaidAt])
}

// ───────────────────────── Settings — настройки заведения ──────────────
// Одна строка (singleton, id = "singleton"): общие данные заведения и
// редактируемые тексты публичной страницы заявок /book. Меняется в админке
// (/settings) — ADMIN. Создаётся лениво через upsert при первом сохранении.

model Settings {
  id String @id @default("singleton")

  // Заведение
  companyName String  @default("OFFICE 2020")
  logoUrl     String? // логотип как data-URL (base64) — показ в сайдбаре и на /book
  phone       String?
  whatsapp    String?
  instagram   String?
  email       String?
  address     String?
  requisites  String? // реквизиты/доп. информация для счетов

  // Глобальные правила брони
  minBookingHours   Int @default(3) // минимальный «пол» длительности поверх объектных minHours
  prepaymentPercent Int @default(0) // % предоплаты по умолчанию (0 = не применять)

  // Публичная страница заявок /book (двуязычно ru/kk; пусто → берётся i18n-дефолт)
  publicTitleRu    String?
  publicTitleKk    String?
  publicSubtitleRu String?
  publicSubtitleKk String?
  publicInfoRu     String? // условия/доп. информация (многострочно)
  publicInfoKk     String?
  publicContacts   String? // контакты для клиента (телефон/whatsapp, одной строкой)

  updatedAt DateTime @updatedAt
}

// ───────────────────────── BookingAddon (§5.6) ─────────────────────────

model BookingAddon {
  id             String       @id @default(cuid())
  bookingId      String
  booking        Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addonId        String
  addon          ServiceAddon @relation(fields: [addonId], references: [id])
  qty            Int          @default(1)
  priceAtBooking Decimal      @db.Decimal(12, 2)

  @@index([bookingId])
  @@index([addonId])
}

// ───────────────────────── BookingAudit — журнал изменений брони ────────
// Кто/когда/что менял. Пишется в той же транзакции, что и create/update/cancel.
model BookingAudit {
  id        String             @id @default(cuid())
  bookingId String
  booking   Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation("BookingAuditUser", fields: [userId], references: [id])
  action    BookingAuditAction
  changes   Json? // для UPDATE: [{field, from, to}]; для CREATE/CANCEL — null
  createdAt DateTime           @default(now())

  @@index([bookingId, createdAt])
}
